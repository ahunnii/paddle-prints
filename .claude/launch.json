{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@paddle-prints/web", "dev"],
      "port": 3000
    },
    {
      "name": "prod",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@paddle-prints/web", "start"],
      "port": 3000
    },
    {
      "name": "tiles",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["tiles:serve"],
      "port": 8080
    }
  ]
}
