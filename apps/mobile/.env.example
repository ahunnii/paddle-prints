# Base URL the mobile app uses to reach the tRPC API (apps/web).
#
# - Physical device on the same LAN: http://192.168.1.x:3000 (your machine's LAN IP)
# - Android emulator:                http://10.0.2.2:3000
# - iOS simulator:                    http://localhost:3000
EXPO_PUBLIC_API_URL=http://192.168.1.x:3000

# Base URL of the Michigan PMTiles archive, consumed by MapLibre via the native
# `pmtiles://` protocol. The map style's `openmaptiles` source url is rewritten to
# `pmtiles://${EXPO_PUBLIC_TILES_URL}` at runtime.
#
# - Physical device on the same LAN: http://192.168.1.x:8080/michigan.pmtiles (your machine's LAN IP)
# - Android emulator:                http://10.0.2.2:8080/michigan.pmtiles
# - iOS simulator:                    http://localhost:8080/michigan.pmtiles
# - Release:                         https://tiles.<your-domain>/michigan.pmtiles
EXPO_PUBLIC_TILES_URL=http://192.168.1.x:8080/michigan.pmtiles
