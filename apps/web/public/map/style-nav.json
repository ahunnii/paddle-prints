{
  "version": 8,
  "name": "Paddle Prints Nav",
  "metadata": {
    "paddleprints:provenance": "Hand-written high-contrast variant of the main Paddle Prints style, for on-water trip recording."
  },
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "pmtiles://__TILES_URL__"
    }
  },
  "glyphs": "/map/glyphs/{fontstack}/{range}.pbf",
  "sprite": "/map/sprite/osm-liberty",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#0a0e12"
      }
    },
    {
      "id": "landcover",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "paint": {
        "fill-color": "#12181d"
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "paint": {
        "fill-color": "#12181d"
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": {
        "fill-color": "#141b16",
        "fill-opacity": 0.8
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": [
        "all",
        [
          "!=",
          "brunnel",
          "tunnel"
        ]
      ],
      "paint": {
        "fill-color": "#00b4ef"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "filter": [
        "all",
        [
          "!=",
          "brunnel",
          "tunnel"
        ]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#00c8ff",
        "line-width": {
          "base": 1.3,
          "stops": [
            [
              6,
              1
            ],
            [
              10,
              2.5
            ],
            [
              12,
              4.5
            ],
            [
              14,
              7
            ],
            [
              16,
              11
            ],
            [
              20,
              20
            ]
          ]
        }
      }
    },
    {
      "id": "waterway_name",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "minzoom": 10,
      "filter": [
        "==",
        "$type",
        "LineString"
      ],
      "layout": {
        "symbol-placement": "line",
        "text-field": "{name}",
        "text-font": [
          "Noto Sans Medium"
        ],
        "text-size": 16
      },
      "paint": {
        "text-color": "#bdf4ff",
        "text-halo-color": "#00303f",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "water_name_point",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "water_name",
      "filter": [
        "==",
        "$type",
        "Point"
      ],
      "layout": {
        "text-field": "{name}",
        "text-font": [
          "Noto Sans Medium"
        ],
        "text-size": 16
      },
      "paint": {
        "text-color": "#bdf4ff",
        "text-halo-color": "#00303f",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "road_major_casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "all",
        [
          "!in",
          "brunnel",
          "bridge",
          "tunnel"
        ],
        [
          "in",
          "class",
          "motorway",
          "trunk",
          "primary",
          "secondary"
        ]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#3a3f44",
        "line-width": {
          "base": 1.3,
          "stops": [
            [
              6,
              1
            ],
            [
              12,
              3
            ],
            [
              16,
              8
            ]
          ]
        }
      }
    },
    {
      "id": "road_major",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "all",
        [
          "!in",
          "brunnel",
          "bridge",
          "tunnel"
        ],
        [
          "in",
          "class",
          "motorway",
          "trunk",
          "primary",
          "secondary"
        ]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#6b7280",
        "line-width": {
          "base": 1.3,
          "stops": [
            [
              6,
              0.5
            ],
            [
              12,
              1.5
            ],
            [
              16,
              4
            ]
          ]
        }
      }
    },
    {
      "id": "place_city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 5,
      "filter": [
        "==",
        "class",
        "city"
      ],
      "layout": {
        "text-field": "{name_en}",
        "text-font": [
          "Noto Sans Medium"
        ],
        "text-size": {
          "base": 1.2,
          "stops": [
            [
              7,
              16
            ],
            [
              11,
              26
            ]
          ]
        },
        "text-anchor": "bottom"
      },
      "paint": {
        "text-color": "#f5f7fa",
        "text-halo-color": "#0a0e12",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place_town",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": [
        "==",
        "class",
        "town"
      ],
      "layout": {
        "text-field": "{name_en}",
        "text-font": [
          "Noto Sans Regular"
        ],
        "text-size": {
          "base": 1.2,
          "stops": [
            [
              7,
              14
            ],
            [
              11,
              18
            ]
          ]
        },
        "text-anchor": "bottom"
      },
      "paint": {
        "text-color": "#e5e9ee",
        "text-halo-color": "#0a0e12",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place_village",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": [
        "==",
        "class",
        "village"
      ],
      "layout": {
        "text-field": "{name_en}",
        "text-font": [
          "Noto Sans Regular"
        ],
        "text-size": {
          "base": 1.2,
          "stops": [
            [
              10,
              13
            ],
            [
              15,
              18
            ]
          ]
        }
      },
      "paint": {
        "text-color": "#d5dae0",
        "text-halo-color": "#0a0e12",
        "text-halo-width": 1.5
      }
    }
  ]
}