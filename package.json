{
  "name": "paddle-prints-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev": "turbo dev --filter=@paddle-prints/web",
    "dev:mobile": "pnpm --filter @paddle-prints/mobile dev",
    "android": "pnpm --filter @paddle-prints/mobile android",
    "ios": "pnpm --filter @paddle-prints/mobile ios",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "db:studio": "turbo db:studio",
    "test:offline": "pnpm --filter @paddle-prints/web test:offline",
    "test:recorder": "pnpm --filter @paddle-prints/web test:recorder",
    "test:rivers": "pnpm --filter @paddle-prints/web test:rivers",
    "tiles:serve": "./scripts/tiles-serve.sh"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.2"
  }
}
